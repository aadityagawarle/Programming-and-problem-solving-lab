n = int(input("dimension: "))

print("first matrix:")
A = [list(map(int, input().split())) 
for _ in range(n)]

print("second matrix:")
B = [list(map(int, input().split())) 
	for _ in range(n)]

result = [[sum(A[i][k] * B[k][j] 
			   for k in range(n)) 
		   for j in range(n)] 
		  for i in range(n)]

print("Resultant Matrix:")
for row in result:
    print(*row)
